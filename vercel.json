{
  "version": 2,
  "builds": [{ "src": "**/*", "use": "@vercel/static" }],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://dual.cn101.cn/$1",
      "permanent": true,
      "has": [{ "type": "host", "value": "amazon-tiktok-strategy-site.vercel.app" }]
    }
  ],
  "trailingSlash": false
}
